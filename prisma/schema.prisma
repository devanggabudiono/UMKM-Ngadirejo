// =============================================
// UMKM Ngadirejo — Prisma Schema
// PostgreSQL database with normalized tables
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tabel utama UMKM
model Umkm {
  id               Int       @id @default(autoincrement())
  slug             String    @unique
  nama             String
  pemilik          String?
  kategori         String
  deskripsiSingkat  String?   @map("deskripsi_singkat")
  deskripsiLengkap  String?   @map("deskripsi_lengkap")
  produk           Json?
  alamat           String?
  latitude         Decimal?  @db.Decimal(10, 8)
  longitude        Decimal?  @db.Decimal(11, 8)
  googleMaps       String?   @map("google_maps")
  whatsapp         String?
  berkenan         String?
  qris             String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  operasional Operasional[]
  images      Image[]
  tags        UmkmTag[]

  @@index([slug])
  @@index([kategori])
  @@index([latitude, longitude])
  @@map("umkm")
}

/// Jam operasional per hari
model Operasional {
  id     Int     @id @default(autoincrement())
  umkmId Int     @map("umkm_id")
  hari   Hari
  buka   String  @default("00:00")
  tutup  String  @default("00:00")
  libur  Boolean @default(false)

  umkm Umkm @relation(fields: [umkmId], references: [id], onDelete: Cascade)

  @@unique([umkmId, hari])
  @@map("operasional")
}

/// Tabel tags
model Tag {
  id   Int    @id @default(autoincrement())
  nama String @unique

  umkms UmkmTag[]

  @@map("tags")
}

/// Junction table UMKM <-> Tags (many-to-many)
model UmkmTag {
  umkmId Int @map("umkm_id")
  tagId  Int @map("tag_id")

  umkm Umkm @relation(fields: [umkmId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([umkmId, tagId])
  @@map("umkm_tags")
}

/// Tabel gambar
model Image {
  id        Int     @id @default(autoincrement())
  umkmId    Int     @map("umkm_id")
  imagePath String  @map("image_path")
  isCover   Boolean @default(false) @map("is_cover")
  sortOrder Int     @default(0) @map("sort_order")

  umkm Umkm @relation(fields: [umkmId], references: [id], onDelete: Cascade)

  @@index([umkmId, isCover])
  @@map("images")
}

enum Hari {
  senin
  selasa
  rabu
  kamis
  jumat
  sabtu
  minggu
}
